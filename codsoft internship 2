import random
import string
def generate_password():
    print("=" * 50)
    print("         PASSWORD GENERATOR TOOL")
    print("=" * 50) 
    try:
        length = int(input("\nEnter the desired password length: "))
        if length <= 0:
            print("\nError: Password length must be greater than 0!")
            return
        elif length < 4:
            print("\nWarning: Short passwords are easier to crack!")
        print("\nSelect password complexity:")
        print("1. Letters only (weak)")
        print("2. Letters and numbers (medium)")
        print("3. Letters, numbers, and symbols (strong)")
        complexity = input("\nEnter your choice (1-3): ")
        if complexity == '1':
            characters = string.ascii_letters
            strength = "WEAK"
        elif complexity == '2':
            characters = string.ascii_letters + string.digits
            strength = "MEDIUM"
        elif complexity == '3':
            characters = string.ascii_letters + string.digits + string.punctuation
            strength = "STRONG"
        else:
            print("\nInvalid choice! Using default (letters, numbers, symbols)")
            characters = string.ascii_letters + string.digits + string.punctuation
            strength = "STRONG"
        password = ''
        for i in range(length):
            password += random.choice(characters)
        print("\n" + "-" * 50)
        print(f"Generated Password ({strength} - {length} characters):")
        print(f"\033[1;32;40m{password}\033[0m")  
        print("-" * 50)
        print("\nPassword Analysis:")
        print(f"Length: {length} characters")
        print(f"Contains uppercase: {any(c.isupper() for c in password)}")
        print(f"Contains lowercase: {any(c.islower() for c in password)}")
        print(f"Contains numbers: {any(c.isdigit() for c in password)}")
        print(f"Contains symbols: {any(c in string.punctuation for c in password)}")     
    except ValueError:
        print("\nError: Please enter a valid number for length!")
    except Exception as e:
        print(f"\nAn unexpected error occurred: {e}")
    print("\n" + "=" * 50)
if __name__ == "__main__":
    generate_password()    
    while True:
        continue_choice = input("\nDo you want to generate another password? (yes/no): ").lower()
        if continue_choice == 'yes' or continue_choice == 'y':
            generate_password()
        elif continue_choice == 'no' or continue_choice == 'n':
            print("\nThank you for using the Password Generator. Stay secure!")
            break
        else:
            print("Please enter 'yes' or 'no'")
